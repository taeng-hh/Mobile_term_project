<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_hill">
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33000000" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <View
                android:layout_width="match_parent"
                android:layout_height="90dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="퀴즈 선택"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:id="@+id/cardQuiz1"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="14dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="#B3FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvQuizTitle1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="개념 초급"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
                <TextView
                    android:id="@+id/tvQuizDesc1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기초 개념 문제를 풀어볼 수 있어요"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardQuiz2"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="14dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="#B3FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvQuizTitle2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="개념 중급"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
                <TextView
                    android:id="@+id/tvQuizDesc2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="조금 더 어려운 문제를 풀어볼 수 있어요"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardQuiz3"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="14dp"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="#B3FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/tvQuizTitle3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="개념 고급"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#222222" />
                <TextView
                    android:id="@+id/tvQuizDesc3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="심화 문제를 풀어볼 수 있어요"
                    android:textSize="13sp"
                    android:textColor="#444444"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardLocked1"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="#88999999"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:contentDescription="잠금 아이콘" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvQuizTitle4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="실전 문제 1"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                    <TextView
                        android:id="@+id/tvQuizDesc4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="개념 중급 클리어 후 해금"
                        android:textSize="13sp"
                        android:textColor="#EEEEEE"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardLocked2"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="#88999999"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:contentDescription="잠금 아이콘" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvQuizTitle5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="실전 문제 2"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                    <TextView
                        android:id="@+id/tvQuizDesc5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="개념 중급 클리어 후 해금"
                        android:textSize="13sp"
                        android:textColor="#EEEEEE"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>