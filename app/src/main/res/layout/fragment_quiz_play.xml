<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6F0F2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View
                android:layout_width="match_parent"
                android:layout_height="108dp" />

            <FrameLayout
                android:id="@+id/quizCharacterProfile"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_quiz_profile_box"
                android:padding="2.5dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToOutline="true"
                    android:outlineProvider="background"
                    android:background="@drawable/bg_quiz_profile_inner">

                    <ImageView
                        android:id="@+id/quizCharacterBase"
                        android:layout_width="190dp"
                        android:layout_height="190dp"
                        android:layout_gravity="center|bottom"
                        android:layout_marginBottom="-59dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/character_base" />

                    <ImageView
                        android:id="@+id/quizClothesImage"
                        android:layout_width="190dp"
                        android:layout_height="190dp"
                        android:layout_gravity="center|bottom"
                        android:layout_marginBottom="-59dp"
                        android:scaleType="fitCenter" />

                    <ImageView
                        android:id="@+id/quizFaceImage"
                        android:layout_width="190dp"
                        android:layout_height="190dp"
                        android:layout_gravity="center|bottom"
                        android:layout_marginBottom="-59dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/face_default" />

                    <ImageView
                        android:id="@+id/quizHatImage"
                        android:layout_width="190dp"
                        android:layout_height="190dp"
                        android:layout_gravity="center|bottom"
                        android:layout_marginBottom="-59dp"
                        android:scaleType="fitCenter" />
                </FrameLayout>
            </FrameLayout>

            <!-- 문제 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="150dp"
                android:background="@drawable/bg_quiz_question"
                android:orientation="vertical"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingTop="22dp"
                android:paddingEnd="20dp"
                android:paddingBottom="22dp">

                <TextView
                    android:id="@+id/tvQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:lineSpacingMultiplier="1.25"
                    android:text="문제가 여기에 표시됩니다."
                    android:textColor="#2B2B2B"
                    android:textSize="21sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 보기 영역 -->
            <RadioGroup
                android:id="@+id/radioGroupOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/option1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_message_box"
                    app:buttonTint="@color/quiz_radio_color"
                    android:paddingStart="16dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp"
                    android:text="보기 1"
                    android:textColor="#2B2B2B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/option2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_message_box"
                    app:buttonTint="@color/quiz_radio_color"
                    android:paddingStart="16dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp"
                    android:text="보기 2"
                    android:textColor="#2B2B2B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/option3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_message_box"
                    app:buttonTint="@color/quiz_radio_color"
                    android:paddingStart="16dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp"
                    android:text="보기 3"
                    android:textColor="#2B2B2B"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/option4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_message_box"
                    app:buttonTint="@color/quiz_radio_color"
                    android:paddingStart="16dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="18dp"
                    android:text="보기 4"
                    android:textColor="#2B2B2B"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </RadioGroup>

            <!-- 제출 버튼 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSubmit"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_btn_submit"
                android:backgroundTint="@null"
                android:elevation="6dp"
                android:minHeight="0dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:text="다음"
                android:textAllCaps="false"
                android:textColor="#2B2B2B"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <!-- 정답 / 오답 이펙트 -->
    <FrameLayout
        android:id="@+id/layoutResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000" />

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_popup_panel"
            android:elevation="8dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="20dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottieEffect"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:visibility="visible"
                app:lottie_autoPlay="false"
                app:lottie_loop="false" />

            <TextView
                android:id="@+id/tvResultStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:text="정답입니다!"
                android:textColor="#2B2B2B"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>