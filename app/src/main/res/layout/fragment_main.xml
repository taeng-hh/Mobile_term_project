<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6F0F2">

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="58dp"
        android:src="@drawable/logo"
        android:contentDescription="로고"
        android:adjustViewBounds="true"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 바깥 테두리 카드 -->
    <FrameLayout
        android:id="@+id/sceneCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="150dp"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_scene_card_border"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/msg_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1">

        <!-- 안쪽 실제 내용 카드 -->
        <FrameLayout
            android:id="@+id/sceneCardInner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2.5dp"
            android:background="@drawable/bg_scene_card_inner"
            android:clipToOutline="true"
            android:outlineProvider="background">

            <!-- 카드 안 배경 -->
            <ImageView
                android:id="@+id/bgInterior"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/background_hill" />

            <!-- 캐릭터 레이어 묶음 -->
            <FrameLayout
                android:id="@+id/characterContainer"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="26dp">

                <ImageView
                    android:id="@+id/characterImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/character_base" />

                <ImageView
                    android:id="@+id/clothes_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/face_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />

                <ImageView
                    android:id="@+id/hat_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter" />
            </FrameLayout>

        </FrameLayout>
    </FrameLayout>

    <!-- 캐릭터 하단 메시지창 -->
    <FrameLayout
        android:id="@+id/msg_container"
        android:layout_width="0dp"
        android:layout_height="110dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="62dp"
        android:background="@drawable/bg_message_box"
        android:padding="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp">

        <TextView
            android:id="@+id/tv_message"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="안녕! 잘 지냈어?!"
            android:textColor="#000000"
            android:textSize="20sp" />
    </FrameLayout>

    <!-- 설정 버튼 -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="54dp"
        android:layout_height="48dp"
        android:layout_marginTop="80dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_circle_button"
        android:contentDescription="설정"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/button_setting"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp" />

    <!-- 어두운 배경 오버레이 -->
    <View
        android:id="@+id/dimView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#66000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp"/>

    <!-- 도움말 팝업 -->
    <LinearLayout
        android:id="@+id/helpPopup"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:maxHeight="500dp"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="도움말"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp">

            <TextView
                android:id="@+id/tvHelpContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="도움말 내용 작성하기"
                android:textColor="#2B2B2B"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:elevation="6dp"/>
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCloseHelpPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>

    <!-- 소리 설정 팝업 -->
    <LinearLayout
        android:id="@+id/soundSettingsPopup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="소리 설정"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <!-- 음성 ON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="15dp">

            <FrameLayout
                android:id="@+id/btnSoundOn"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_btn_inset"
                android:padding="12dp"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:id="@+id/iconSpeaker"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/speaker_icon"
                    android:contentDescription="음성 ON" />
            </FrameLayout>

            <!-- 뮤트 ON -->
            <FrameLayout
                android:id="@+id/btnSoundMute"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_btn_inset"
                android:padding="12dp"
                android:layout_marginStart="10dp">

                <ImageView
                    android:id="@+id/iconMute"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/mute_icon"
                    android:contentDescription="음성 OFF" />
            </FrameLayout>
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCloseSoundPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>

    <!-- 팝업창 -->
    <LinearLayout
        android:id="@+id/settingsPopup"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_popup_panel"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:elevation="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:text="설정"
            android:textColor="#2B2B2B"
            android:textSize="24sp"
            android:textStyle="bold"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="소리 설정"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="도움말"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/logoutBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="로그아웃"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_inset_red"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClosePopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:text="닫기"
            android:textColor="#2B2B2B"
            android:background="@drawable/bg_btn_inset"
            android:backgroundTint="@null"
            android:minHeight="0dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:elevation="6dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>